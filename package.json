{
  "name": "subpar_forcasting",
  "version": "0.1.0",
  "private": true,
  "description": "Subpar Forcasting - a yearly prediction game",
  "scripts": {
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "start": "concurrently \"npm run frontend:start\" \"npm run backend:start\"",
    "build": "npm run frontend:build && npm run backend:build",
    "test": "npm run frontend:test && npm run backend:test",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:test": "cd frontend && npm test",
    "backend:dev": "cd backend && npm run dev",
    "backend:start": "cd backend && npm start",
    "backend:test": "cd backend && npm test",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "clean": "rm -rf frontend/node_modules backend/node_modules node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.10.1",
    "concurrently": "^7.6.0",
    "dotenv": "^17.2.3"
  },
  "dependencies": {
    "@coursetable/passport-cas": "^0.1.4",
    "react-router-dom": "^7.9.3",
    "socket.io": "^4.8.1"
  }
}
