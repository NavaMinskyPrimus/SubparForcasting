{
    "name": "yorkie-frontend",
    "version": "0.1.0",
    "private": true,
    "dependencies": {
        "react": "^19.1.1",
        "react-datepicker": "^8.8.0",
        "react-day-picker": "^9.11.1",
        "react-dom": "^19.1.1",
        "react-hook-form": "^7.66.0",
        "react-icons": "^5.5.0",
        "react-router-dom": "^7.9.3"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
        "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
        "prettier:write": "prettier --write \"{src,tests}/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
        "prettier:check": "prettier --check \"{src,tests}/**/*.{ts,tsx,js,jsx,json,css,scss}\"",
        "test": "jest"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
